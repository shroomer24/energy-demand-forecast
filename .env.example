# ── EIA Open Data API ─────────────────────────────────────────────────────────
# Register for a free key at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# ── TabPFN-3 (Prior Labs / SAP) ───────────────────────────────────────────────
# Register for a free key at: https://tabpfn.com
TABPFN_API_KEY=your_tabpfn_api_key_here
TABPFN_USE_API=1

# Apple Silicon MPS memory control
TABPFN_MPS_MEMORY_FRACTION=0.7

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
